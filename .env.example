# Скопіюй у .env (локально) або задай у Render → Environment.

# Обов'язково на Render: NODE_ENV=production і довгий випадковий рядок.
PANEL_SESSION_SECRET=

# JSON-масив облікових записів (один рядок у Render UI).
# password: bcrypt-хеш (рекомендовано) або відкритий рядок лише для dev.
# Хеш: node -e "console.log(require('bcryptjs').hashSync('Пароль',10))"
PANEL_ACCOUNTS=[{"username":"admin","password":"change-me"}]

# NODE_ENV=production
# CHAT_APP_UPSTREAM=https://chat-app-anzi.onrender.com
# PORT — на Render задається автоматично
# HOST=0.0.0.0
